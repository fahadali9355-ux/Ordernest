    },
    {
      "page": "/dashboard/notifications",
      "regex": "^/dashboard/notifications(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/notifications(?:/)?$"
    },
    {
      "page": "/dashboard/orders",
      "regex": "^/dashboard/orders(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/orders(?:/)?$"
    },
    {
      "page": "/dashboard/products",
      "regex": "^/dashboard/products(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/products(?:/)?$"
    },
    {
      "page": "/dashboard/settings",
      "regex": "^/dashboard/settings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/settings(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/legal/data-deletion",
      "regex": "^/legal/data\\-deletion(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/legal/data\\-deletion(?:/)?$"
